{
  "name": "memory-lightrag-local",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:dist": "tsc -p tsconfig.build.json",
    "test": "npm run test:unit",
    "test:unit": "npm run build:dist && node --test test/**/*.test.mjs",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write '**/*.ts'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
